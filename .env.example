VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Note: OpenRouter API key now lives server-side in the ai-transaction edge function.
# Set it via: supabase secrets set OPENROUTER_API_KEY=your_key
# Do NOT add VITE_OPENROUTER_API_KEY here — it is no longer read by the client.
